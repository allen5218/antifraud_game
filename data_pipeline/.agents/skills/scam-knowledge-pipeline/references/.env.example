# Copy this file outside the skill package, for example to:
#   /Users/allen/Dev/antifraud_game/data_pipeline/.env
#
# Do not put real secrets in references/.env.example.
# Scripts load the external .env path passed with --env-file or the process environment.

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Optional PG* variables if DATABASE_URL is not used:
# PGHOST=HOST
# PGPORT=5432
# PGDATABASE=DBNAME
# PGUSER=USER
# PGPASSWORD=PASSWORD

# Embedding settings for production vectorization:
EMBEDDING_PROVIDER=gemini
EMBEDDING_DIM=1536
EMBEDDING_MODEL=gemini-embedding-2

# Put the real key only in your external .env or process environment.
# Gemini client libraries also accept GOOGLE_API_KEY; if both are set,
# Google documents that GOOGLE_API_KEY takes precedence.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Optional smoke-test override without external API calls:
# EMBEDDING_PROVIDER=fake
# EMBEDDING_MODEL=fake-deterministic-v1
