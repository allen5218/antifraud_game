# 自托管 Supabase(production).env 範本 —— 複製為 deploy/supabase/.env 後填入真值
# 所有值皆為佔位;真值只進主機 deploy/supabase/.env,絕不進 git。
# 密鑰產生見官方文件:https://supabase.com/docs/guides/self-hosting/docker

############ 核心密鑰(務必以強隨機值取代)############
POSTGRES_PASSWORD=
JWT_SECRET=
ANON_KEY=
SERVICE_ROLE_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
JWT_KEYS=
JWT_JWKS=
SECRET_KEY_BASE=
VAULT_ENC_KEY=
PG_META_CRYPTO_KEY=

############ Studio 後台登入 ############
DASHBOARD_USERNAME=
DASHBOARD_PASSWORD=

############ Postgres / Pooler(連線契約見 README)############
POSTGRES_HOST=db
POSTGRES_DB=postgres
# ⚠️ 上游 compose 把 POSTGRES_PORT 同時當成「db 容器內部 PGPORT」與
#    「supavisor session 埠的 host 發布埠」(ports: ${POSTGRES_PORT}:5432)。
#    若主機 5432 已被原生 Postgres 佔用,改成其他埠(例:54323)即可,
#    stack 內部一致、遊戲 backend 走容器埠 supavisor:5432 不受影響。
POSTGRES_PORT=5432
POOLER_PROXY_PORT_TRANSACTION=6543
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
POOLER_TENANT_ID=
POOLER_DB_POOL_SIZE=5

############ 對外 URL(填 production 域名)############
SUPABASE_PUBLIC_URL=
API_EXTERNAL_URL=
SITE_URL=
ADDITIONAL_REDIRECT_URLS=
KONG_HTTP_PORT=54321
KONG_HTTPS_PORT=54329

############ Auth ############
JWT_EXPIRY=3600
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify

############ SMTP(如需寄信;不需可留空)############
SMTP_ADMIN_EMAIL=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=

############ Storage / S3(預設 file 後端可留預設)############
GLOBAL_S3_BUCKET=stub
REGION=stub
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
STORAGE_TENANT_ID=stub

############ Studio 顯示 ############
STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=antifraud-game

############ PostgREST ############
PGRST_DB_SCHEMAS=public,storage,graphql_public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public,extensions

############ Functions / 其他 ############
FUNCTIONS_VERIFY_JWT=false
DOCKER_SOCKET_LOCATION=/var/run/docker.sock
# OPENAI_API_KEY 供 Studio SQL 助手(選填)
OPENAI_API_KEY=
# Logflare(選填分析)
LOGFLARE_PUBLIC_ACCESS_TOKEN=
LOGFLARE_PRIVATE_ACCESS_TOKEN=
