# ============================================================
# 反詐騙訓練遊戲 — 環境變數設定
# 複製此檔案為 .env 並填入實際值
# cp .env.example .env
# ============================================================

# ── 網域與環境 ──────────────────────────────────────────────

# 部署網域（Traefik 用於路由和 TLS 憑證）
# 本機開發: localhost
# 正式部署: your-domain.com
DOMAIN=localhost

# 前端網址（後端用來產生 Email 中的連結）
# 本機開發: http://localhost:5173
# 正式部署: https://dashboard.your-domain.com
FRONTEND_HOST=http://localhost:5173

# 環境模式: local | staging | production
# local: 啟用 /private 路由、寬鬆安全檢查
# staging/production: 強制要求 SECRET_KEY 變更
ENVIRONMENT=local

# 專案名稱（顯示在 API docs 等處）
PROJECT_NAME="反詐騙訓練遊戲"
STACK_NAME=anti-fraud-game

# ── 後端 ────────────────────────────────────────────────────

# CORS 允許的來源（逗號分隔）
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:5173"

# JWT 簽名密鑰（正式部署務必更換！）
# 產生方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=changethis

# 初始超級使用者帳號（首次啟動時自動建立）
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# ── Google Gemini API（必填！遊戲核心功能）──────────────────

# 從 https://aistudio.google.com/apikey 取得
# 遊戲的 AI 出題功能完全依賴此 API Key（模型：gemini-3.5-flash）
GOOGLE_API_KEY=your-gemini-api-key-here

# ── Email（選填，用於密碼重設等功能）───────────────────────

SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# ── PostgreSQL（自托管 Supabase pooler）─────────────────────

# dev 統一走本機 Supabase pooler（supabase start 後對外埠,預設 54323）;
# 正式部署由 deploy/.env 指向 compose 內服務名 supavisor:5432（見 deploy/supabase/README.md）。
POSTGRES_SERVER=localhost
POSTGRES_PORT=54323
POSTGRES_DB=postgres
# Supabase pooler 使用者格式為 postgres.<project-ref/tenant-id>
POSTGRES_USER=postgres.your-tenant-id
# 正式部署務必更換！
POSTGRES_PASSWORD=changethis

# ── 監控（選填）─────────────────────────────────────────────

SENTRY_DSN=

# ── Cloudflare Tunnel（正式部署時設定）─────────────────────

# 從 Cloudflare Zero Trust 面板 → Networks → Tunnels 取得
# 本機開發不需要設定
CLOUDFLARE_TUNNEL_TOKEN=

# ── Docker Registry（正式部署時設定）────────────────────────

DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend
